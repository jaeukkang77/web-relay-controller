{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.ts$": [
      "ts-jest",
      {
        "tsconfig": "<rootDir>/../tsconfig.test.json",
        "diagnostics": false
      }
    ]
  },
  "moduleNameMapper": {
    "^@repo/prisma-db(.*)$": "<rootDir>/../packages/prisma-db/src$1"
  }
}
