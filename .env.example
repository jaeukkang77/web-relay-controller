# ── Database (PostgreSQL 컨테이너 설정) ───────────────────────
DB_USER=relay
DB_PASSWORD=your_secure_password
DB_NAME=relay_db

# ── JWT ───────────────────────────────────────────────────────
# 최소 32자 이상. 생성 명령:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── Internal API ──────────────────────────────────────────────
INTERNAL_SECRET=

# ── CORS ──────────────────────────────────────────────────────
# nginx가 서비스하는 외부 도메인 또는 IP
# 예: https://yourname.iptime.org
CORS_ORIGIN=https://yourname.iptime.org
