{
  "name": "web-relay-controller",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm --filter @repo/prisma-db build && pnpm --parallel --filter=@repo/api --filter=web dev",
    "dev:api": "pnpm --filter=@repo/api start:dev",
    "dev:web": "pnpm --filter=web dev",
    "build": "pnpm -r build",
    "build:api": "pnpm --filter=@repo/api build",
    "build:web": "pnpm --filter=web build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter=@repo/api exec prisma migrate dev",
    "db:seed": "pnpm --filter=@repo/api exec prisma db seed"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
